# ══════════════════════════════════════════════════════════
#  PK Tech — Backend Environment Variables
#  ⚠  NEVER commit this file to Git.
#     .gitignore already excludes it.
# ══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5000,http://localhost:8000,http://127.0.0.1:8000

# ── Database ──────────────────────────────────────────────
MONGODB_URI=<replace-with-your-mongodb-connection-string>
MONGODB_DB=pktech

# ── Auth / JWT ────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<replace-with-strong-random-secret>
JWT_EXPIRES_IN=7d

# ── Admin seed ────────────────────────────────────────────
ADMIN_EMAIL=<your-admin-email>
ADMIN_PASSWORD=<your-admin-password>

# ── Email / SMTP ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-gmail-address>
# Use a Gmail App Password (not your account password)
# https://myaccount.google.com/apppasswords
SMTP_PASS=<your-gmail-app-password>
MAIL_FROM="PK Tech <your-gmail-address>"
MAIL_TO=<email-to-receive-contact-form-submissions>

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── AI ────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-1.5-flash

# ── Security ──────────────────────────────────────────────
# AES-256 key for encrypting sensitive DB fields (32 random bytes as hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-hex-chars>

# HMAC secret for generated API keys
API_KEY_SECRET=<replace-with-random-string>

# CSRF token signing secret
CSRF_SECRET=<replace-with-random-string>

# ── Redis (optional — for distributed rate limiting) ──────
# REDIS_URL=redis://localhost:6379

# ── Twilio (optional — for SMS notifications) ────────────
# TWILIO_ACCOUNT_SID=<your-account-sid>
# TWILIO_AUTH_TOKEN=<your-auth-token>
# TWILIO_FROM=<your-twilio-phone-number>
