{
  "name": "pktech-backend",
  "version": "2.0.0",
  "description": "Secure Express + MongoDB backend for the PK Tech website.",
  "main": "src/server.js",
  "scripts": {
    "start":  "node src/server.js",
    "dev":    "nodemon src/server.js",
    "seed":   "node ../database/seed.js",
    "check":  "node --check src/server.js"
  },
  "engines": { "node": ">=18" },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cloudinary":         "^2.5.1",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.7",
    "express":            "^4.21.2",
    "express-rate-limit": "^7.4.0",
    "helmet":             "^8.0.0",
    "jsonwebtoken":       "^9.0.2",
    "mongoose":           "^8.9.5",
    "morgan":             "^1.10.0",
    "multer":             "^2.1.1",
    "nodemailer":         "^8.0.9",
    "slugify":            "^1.6.6",
    "streamifier":        "^0.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
